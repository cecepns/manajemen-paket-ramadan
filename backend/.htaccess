Options -Indexes
RewriteEngine On

# Backward compatibility: URL lama /api/uploads/* diarahkan ke /uploads/*
RewriteRule ^api/uploads/(.*)$ /uploads/$1 [L,NC]

# Jika file/folder nyata, jangan rewrite ke index.php
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback ke index.php
RewriteRule ^ index.php [L]

